# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# For local dev, point to ElasticMQ:
AWS_ENDPOINT_URL=http://localhost:9324

# ─── SQS Queue URLs ──────────────────────────────────────────────────────────
SQS_QUEUE_1_URL=http://localhost:9324/000000000000/doc-processing-queue
SQS_QUEUE_2_URL=http://localhost:9324/000000000000/embedding-queue
SQS_QUEUE_3_URL=http://localhost:9324/000000000000/indexing-queue
SQS_DLQ_1_URL=http://localhost:9324/000000000000/doc-processing-dlq
SQS_DLQ_2_URL=http://localhost:9324/000000000000/embedding-dlq
SQS_DLQ_3_URL=http://localhost:9324/000000000000/indexing-dlq

# ─── S3 ──────────────────────────────────────────────────────────────────────
S3_BUCKET=rag-health-local
S3_RAW_PREFIX=raw-docs

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://raghealth:raghealth_local@localhost:5432/raghealth

# ─── Weaviate ────────────────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=  # Leave empty for local (anonymous access enabled)

# ─── LLM Keys ────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_FALLBACK_URL=http://localhost:11434  # Ollama or self-hosted Llama endpoint

# ─── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=biogpt  # biogpt | scibert

# ─── Index Aliases ───────────────────────────────────────────────────────────
LIVE_INDEX_ALIAS=knowledge-live
SHADOW_INDEX_ALIAS=knowledge-shadow
