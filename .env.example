# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
# For local dev, point to ElasticMQ:
AWS_ENDPOINT_URL=http://localhost:9324

# ─── SQS Queue URLs ──────────────────────────────────────────────────────────
SQS_QUEUE_1_URL=http://localhost:9324/000000000000/doc-processing-queue
SQS_QUEUE_2_URL=http://localhost:9324/000000000000/embedding-queue
SQS_QUEUE_3_URL=http://localhost:9324/000000000000/indexing-queue
SQS_DLQ_1_URL=http://localhost:9324/000000000000/doc-processing-dlq
SQS_DLQ_2_URL=http://localhost:9324/000000000000/embedding-dlq
SQS_DLQ_3_URL=http://localhost:9324/000000000000/indexing-dlq

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
S3_BUCKET=rag-health-local
S3_RAW_PREFIX=raw-docs
# Local dev: point boto3 at MinIO instead of real AWS S3
S3_ENDPOINT_URL=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://raghealth:raghealth_local@localhost:5432/raghealth

# ─── Weaviate ────────────────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=  # Leave empty for local (anonymous access enabled)

# ─── LLM ─────────────────────────────────────────────────────────────────────
# Primary is tried first; fallback is used automatically on any failure.
# Supported values: openai | anthropic  (add more in shared/clients/llm_client.py)
LLM_PRIMARY=openai
LLM_FALLBACK=anthropic
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                     # optional, default: gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6       # optional, default: claude-sonnet-4-6
# LLM_FALLBACK_URL=http://localhost:11434  # Ollama / self-hosted (Phase 3)

# ─── Embedding (Phase 2: BiomedBERT via HF Inference API) ────────────────────
# Set EMBEDDING_PROVIDER=hf_inference (default) to use the HF Serverless API.
# Set EMBEDDING_PROVIDER=http_endpoint to route to a self-hosted GPU server
# (Triton, vLLM, or custom FastAPI) — no code changes required.
EMBEDDING_PROVIDER=hf_inference
HF_INFERENCE_URL=https://api-inference.huggingface.co/pipeline/feature-extraction/microsoft/BiomedNLP-BiomedBERT-base-uncased-abstract-fulltext
HF_API_KEY=hf_...
# Self-hosted GPU endpoint (only used when EMBEDDING_PROVIDER=http_endpoint):
# EMBEDDING_ENDPOINT_URL=http://your-gpu-server:8080/embed
# EMBEDDING_API_KEY=  # optional — leave empty if endpoint has no auth

# ─── DLQ Alerting ────────────────────────────────────────────────────────────
# Optional: POST alert here when any DLQ depth > 0 (Phase 2 dev visibility).
# Real CloudWatch/SNS alerting is wired in Phase 5 with production infra.
# DLQ_ALERT_WEBHOOK_URL=http://localhost:9999/dlq-alert

# ─── Index Aliases ───────────────────────────────────────────────────────────
LIVE_INDEX_ALIAS=knowledge-live
SHADOW_INDEX_ALIAS=knowledge-shadow
